meta {
  name: Prepare Dataplane
  type: http
  seq: 5
}

post {
  url: {{cpBaseUrl}}/api/mgmt/v5beta/dataplanes/{{consumer_id}}
  body: json
  auth: inherit
}

body:json {
  {
    "id": "consumer-siglet",
    "allowedTransferTypes": [
      "HttpData-PULL"
    ],
    "url": "http://siglet.edc-v.svc.cluster.local:8081/api/v1/{{consumer_id}}/dataflows"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
